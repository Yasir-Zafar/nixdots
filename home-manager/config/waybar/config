{
    "layer": "top",
    "position": "top",
    "height": 30,

    "modules-left": [ "wireplumber", "battery", "network" ],
    "modules-center": [ "hyprland/workspaces" ],
    "modules-right": [ "clock", "hyprland/submap" ],
    "hyprland/workspaces": {
	    "format": "{icon}",
	    "format-icons": {
	    	"1": "оӨ§",
	    	"2": "о °",
  	  	"3": "оЎҙ",
	    	"4": "оўқ",
  	  	"5": "оӨ•",
  	  	"6": "оӨӣ",
        "focused": "",
        "default": ""
    	},
     "on-click": "activate",
    },
    "clock": {
        "format": " <span color=\"#8ec07c\"> оЎҚ </span> {:%A, %B %d %I:%M %p} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "month",
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#fbf1c7'><b>{}</b></span>",
                              "days":       "<span color='#ebdbb2'><b>{}</b></span>",
                              "weeks":      "<span color='#83a598'><b>W{}</b></span>",
                              "weekdays":   "<span color='#fabd2f'><b>{}</b></span>",
                              "today":      "<span color='#fb4934'><b><u>{}</u></b></span>"
                              }
                    },
    },
    "memory": {
        "interval": 30,
        "format": "  <span color=\"#d3869b\">оЎһ</span> {used} ",
        "max-length": 10
    },
    "hyprland/submap": {
        "format": "{}",
        "max-length": 8,
        "tooltip": false,
    },
    "network": {
        "format-wifi": "  <span color=\"#83a598\">оЈі</span>  {essid} ",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} оҘә",
        "format-linked": "{ifname} (No IP) пһ–",
        "format-disconnected": "  оӨҮ  ",
        "family": "ipv4",
    },
    "wireplumber": {
        "format": "  <span color=\"#83a598\">{icon}</span> {volume} ",
        "format-mut0ed": "оЁҢ {format_source}",
        "format-source": "п„°",
        "format-source-muted": "оЈ®",
        "format-icons": {
            "default": ["оЈұ", "оЈҜ", "оЈ°"]
        },
       "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "  <span color=\"#fe8019\">{icon}</span> {capacity} ",
        "format-charging": "  <span color=\"#fe8019\">о І</span> {capacity} ",
        "format-alt": "  <span color=\"#fe8019\">{icon}</span> {time} ",
        "format-icons": ["о ҙ"]
    },
}
