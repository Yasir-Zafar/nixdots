{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 25, // Waybar height (to be removed for auto height)

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["mpd"],
    "modules-right": [ "hyprland/submap", "memory", "wireplumber", "battery", "network", "clock"],
    "hyprland/workspaces": {
	    "format": "{icon}",
	    "format-icons": {
	    	"1": "",
	    	"2": "",
  	  	"3": "",
	    	"4": "",
  	  	"5": "",
        "focused": "",
        "default": ""
    	},
     "on-click": "activate",
    },
    "hyprland/submap": {
        "format": "{}",
        "max-length": 8,
        "tooltip": false,
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 50, 
        "tooltip": false,
        "separate-outputs": true
    },
    "clock": {
        "format": " <span color=\"#8ec07c\">  </span> {:%I:%M %p} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "month",
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#fbf1c7'><b>{}</b></span>",
                              "days":       "<span color='#ebdbb2'><b>{}</b></span>",
                              "weeks":      "<span color='#83a598'><b>W{}</b></span>",
                              "weekdays":   "<span color='#fabd2f'><b>{}</b></span>",
                              "today":      "<span color='#fb4934'><b><u>{}</u></b></span>"
                              }
                    },
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "  <span color=\"#fe8019\">{icon}</span> {capacity} ",
        "format-charging": "  <span color=\"#fe8019\"></span> {capacity} ",
        "format-alt": "  <span color=\"#fe8019\">{icon}</span> {time} ",
        "format-icons": [""]
    },
    "network": {
        "format-wifi": "  <span color=\"#83a598\"></span>  {essid} ",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "    ",
        "family": "ipv4",
    },
    "wireplumber": {
        "format": "  <span color=\"#83a598\">{icon}</span> {volume} ",
        "format-mut0ed": " {format_source}",
        "format-source": "",
        "format-source-muted": "",
        "format-icons": {
            "default": ["", "", ""]
        },
       "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    },
    "memory": {
        "interval": 30,
        "format": "  <span color=\"#d3869b\"></span> {used} ",
        "max-length": 10
    },
    "mpd": {
        "format": " <span color=\"#fb4934\"></span>  {title} - {album} ",
        "format-disconnected": " <span color=\"#fb4934\"></span>  Disconnected ",
        "format-stopped": " <span color=\"#fb4934\"></span>  Stopped ",
        "interval": 7,
        },
    },
},
